@{
    ViewData["Title"] = "EventEase";
}


<div class="hero">

    <div class="hero-content">

        <h1>EventEase Venue Booking System</h1>

        <p>
            A modern administrative platform for managing venues, events, and bookings
            efficiently. Prevent double bookings, manage venue availability, and
            organize events with ease.
        </p>

        <div class="hero-buttons">

            <a asp-controller="Account" asp-action="Login" class="btn btn-primary me-2" role="button">
                Login
            </a>

            <a asp-controller="Account" asp-action="SignUp" class="btn btn-outline-primary" role="button">
                Sign Up
            </a>

        </div>

    </div>

</div>



<div class="row text-center">

    <div class="col-md-4 mb-4">
        <div class="card shadow">
            <div class="card-body">
                <h4 class="card-title">Venues</h4>
                <p class="card-text">
                    Create, edit, and manage venue information including location, capacity, and images.
                </p>
                <a asp-controller="Venues" asp-action="Index" class="btn btn-primary">
                    Manage Venues
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow">
            <div class="card-body">
                <h4 class="card-title">Events</h4>
                <p class="card-text">
                    Create and manage events before assigning them to venues.
                </p>
                <a asp-controller="Events" asp-action="Index" class="btn btn-success">
                    Manage Events
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow">
            <div class="card-body">
                <h4 class="card-title">Bookings</h4>
                <p class="card-text">
                    Link events to venues and prevent scheduling conflicts.
                </p>
                <a asp-controller="Bookings" asp-action="Index" class="btn btn-warning">
                    Manage Bookings
                </a>
            </div>
        </div>
    </div>

</div>

<hr />



<footer class="footer">

    <p>© 2026 EventEase | Venue Booking System</p>

</footer>