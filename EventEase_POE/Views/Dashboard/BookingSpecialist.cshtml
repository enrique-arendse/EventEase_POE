@{
	ViewData["Title"] = "Dashboard";
}


<h1>Booking Specialist Dashboard</h1>

<div class="dashboard-grid">

	<div class="dashboard-card">
		<h3>Create Booking</h3>
		<p>Assign events to venues.</p>
		<a asp-controller="Bookings" asp-action="Create">New Booking</a>
	</div>

	<div class="dashboard-card">
		<h3>View Bookings</h3>
		<p>Manage upcoming bookings.</p>
		<a asp-controller="Bookings" asp-action="Index">View</a>
	</div>

	<div class="dashboard-card">
		<h3>Events</h3>
		<p>See all upcoming events.</p>
		<a asp-controller="Events" asp-action="Index">Events</a>
	</div>

</div>