@{
    ViewData["Title"] = "Dashboard";
}

<h1>Admin Dashboard</h1>

<div class="dashboard-grid">

    <div class="dashboard-card">
        <h3>Manage Venues</h3>
        <p>Create and edit venues.</p>
        <a asp-controller="Venues" asp-action="Index">Open</a>
    </div>

    <div class="dashboard-card">
        <h3>Manage Events</h3>
        <p>Create and manage events.</p>
        <a asp-controller="Events" asp-action="Index">Open</a>
    </div>

    <div class="dashboard-card">
        <h3>Bookings</h3>
        <p>Manage venue bookings.</p>
        <a asp-controller="Bookings" asp-action="Index">Open</a>
    </div>

    <div class="dashboard-card">
        <h3>Users</h3>
        <p>Manage system users.</p>
        <a asp-controller="Users" asp-action="Index">Open</a>
    </div>

</div>