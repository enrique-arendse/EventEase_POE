@model EventEase_POE.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="card card-elegant p-4">
    <h1 class="mb-3">Delete Venue</h1>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Cannot Delete:</strong> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <a asp-action="Index" class="btn btn-secondary">Back to Venues</a>
    }
    else
    {
        <h3 class="text-danger mb-3">Are you sure you want to delete this venue?</h3>
        <div class="mb-3">
            <h5>@Model.VenueName</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@Model.Location</dd>

                <dt class="col-sm-3">Capacity</dt>
                <dd class="col-sm-9"><span class="badge bg-info">@Model.Capacity</span></dd>

                <dt class="col-sm-3">Image</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <a href="@Model.ImageUrl" target="_blank" class="btn btn-sm btn-outline-primary">View Image</a>
                    }
                    else
                    {
                        <span class="text-muted">No image</span>
                    }
                </dd>
            </dl>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="VenueId" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Yes, Delete Venue</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    }
</div>
