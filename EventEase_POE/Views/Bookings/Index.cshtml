﻿@model IEnumerable<EventEase_POE.Models.BookingDetailViewModel>

@{
    ViewData["Title"] = "Bookings";
}

<div class="card card-elegant p-4 mb-4">
    <h1 class="mb-3">Manage Bookings</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-6">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="searchTerm" class="form-control" placeholder="Search by Booking ID or Event Name..." value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <a href="/Bookings/Index" class="btn btn-secondary">Clear</a>
                }
            </form>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Create" class="btn btn-success">Create New Booking</a>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Booking ID</th>
                        <th>Event</th>
                        <th>Event Date</th>
                        <th>Venue</th>
                        <th>Location</th>
                        <th>Capacity</th>
                        <th>Booking Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.BookingId</strong></td>
                            <td>@item.EventName</td>
                            <td>@item.EventDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.VenueName</td>
                            <td>@item.VenueLocation</td>
                            <td><span class="badge bg-info">@item.VenueCapacity</span></td>
                            <td>@item.BookingDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No bookings found. @if (!string.IsNullOrEmpty(ViewBag.SearchTerm)) { <a href="/Bookings/Index">Clear search</a> }
        </div>
    }
</div>
